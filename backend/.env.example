# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=kt_impex

# Auth
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=8h

# Server
PORT=5000

# AI Agents (Phase 4) — Google Gemini free tier
# Get your free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...
# Override model if needed (default: gemini-2.0-flash)
AGENT_MODEL=gemini-2.0-flash

# Redis cache (Phase 4)
# Install Redis locally: https://redis.io/docs/getting-started/
# Default: redis://127.0.0.1:6379 (no auth, local)
# With password: redis://:yourpassword@127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379
# Set to 'false' to disable caching entirely (e.g. during development without Redis)
CACHE_ENABLED=true
